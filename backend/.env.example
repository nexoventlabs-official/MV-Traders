# Backend Configuration Example
PORT=10000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Paytm Credentials - Get these from your Paytm Dashboard
PAYTM_MID=YOUR_MERCHANT_ID
PAYTM_MERCHANT_KEY=YOUR_MERCHANT_KEY
PAYTM_WEBSITE=DEFAULT
PAYTM_INDUSTRY_TYPE=Retail
PAYTM_CHANNEL_ID=WEB

# Paytm URLs
PAYTM_PAYMENT_URL=https://securegw.paytm.in/order/process
PAYTM_VERIFY_URL=https://securegw.paytm.in/merchant-status/getTxnStatus
PAYTM_CALLBACK_URL=http://localhost:5173/payment-callback

# For staging/testing, use:
# PAYTM_PAYMENT_URL=https://securegw-stage.paytm.in/order/process
# PAYTM_VERIFY_URL=https://securegw-stage.paytm.in/merchant-status/getTxnStatus
